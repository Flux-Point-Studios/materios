# =============================================================================
# Materios .gitignore
# =============================================================================

# ---------------------
# Rust
# ---------------------
target/
*.rs.bk

# ---------------------
# Node / pnpm
# ---------------------
node_modules/
dist/
.pnpm-store

# ---------------------
# IDE
# ---------------------
.vscode/
.idea/

# ---------------------
# Environment variables
# ---------------------
.env
.env.*
!.env.example

# ---------------------
# Kubernetes secrets (never commit)
# ---------------------
k8s/secret*.yaml
**/k8s/secret*.yaml

# ---------------------
# OS
# ---------------------
.DS_Store
Thumbs.db

# ---------------------
# Build artifacts
# ---------------------
out/
*.wasm

# ---------------------
# Docker
# ---------------------
postgres-data/

# ---------------------
# Ops (deploy configs, chain specs, nginx — private)
# ---------------------
ops/

# ---------------------
# Midnight
# ---------------------
midnight/contracts/managed/

# ---------------------
# Python (cert-daemon)
# ---------------------
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
